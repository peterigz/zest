#version 450
#extension GL_EXT_nonuniform_qualifier : require

#define group_size 1024

const float packed_scale_max = 32767.0 / 128.0;
const float lookup_table_sizef = 8.0;
const float lookup_table_size2f = lookup_table_sizef - 1.0;

const int tfx_intensity_offset					= 0;
const int tfx_alpha_sharpness_offset			= 1;
const int tfx_curved_alpha_offset				= 2;
const int tfx_gradient_map_offset			    = 3;
const int tfx_width_offset						= 4;
const int tfx_scale_offset						= 5;
const int tfx_uv_offset_y_offset				= 6;
const int tfx_uv_scale_y_offset					= 7;
const int tfx_clip_offset_overtime_offset  	    = 8;
const int tfx_clip_size_overtime_offset  	    = 9;
const int tfx_intensity_overlength_offset  	    = 10;
const int tfx_alpha_sharpness_overlength_offset = 11;
const int tfx_curved_alpha_overlength_offset  	= 12;
const int tfx_gradient_map_overlength_offset  	= 13;
const int tfx_width_overlength_offset			= 14;
const int tfx_fixed_angle_offset				= 15;

const int tfx_active_mask       = 0x1;
const int tfx_relative_mask     = 0x2;

/*
This compute shader takes in a buffer of ribbon segments and builds a vertex and index buffer for consumption by the vertex
shader. The push constant contains data such as the number of individual ribbons and the segment count of each ribbon. All 
ribbons are the same length passed into the push constant as segment_count.
*/

struct tfx_ribbon_segment {
    vec3 position;                      // xyz = position, w = width                
	uint intensity_gradient_map;		//Multiplier for the color of the ribbon and the gradient map value
	uint curved_alpha;  				//Sharpness and dissolve amount value for fading the image
    uint padding[3];
};

struct tfx_ribbon {
    vec4 position;                      //normalised age is in w
    float width;
	uint segment_start_index;
	uint flags;
	uint captured_index;
	uvec2 quaternion;                   //16-bit snorm quaternion: .x = X|Y, .y = Z|W
    uint emitter_index;
	uint texture_indexes;
	uint intensity_gradient_map;		//Multiplier for the color of the ribbon
	uint curved_alpha;	    			//Sharpness and dissolve amount value for fading the image
	uint _padding[2];                   //Padding to 64 bytes for std430 alignment
};

struct tfx_vertex {
    vec3 position;
    uint segment_index;
    vec2 uv_offset_scale;
    uint ribbon_index;
    uint clipped;
};

const uint tfx_angle_type_face_camera   = 0;
const uint tfx_angle_type_fixed_angle   = 1;
const uint tfx_angle_type_frenet_serret = 2;

struct tfx_emitter {
	vec4 quaternion;
    vec3 position;
    uint lookup_offset;
    vec3 captured_position;
    uint padding1;
    vec3 scale;
    uint padding2;
    vec3 fixed_angle_normal;
    uint angle_type;
};

struct tfx_gpu_graph_data {
	vec4 node_data;
	vec4 oscillator;
	int easing_type;
	int flags;
	int padding[2];
};

layout(push_constant) uniform push_constants
{
    vec4 camera_position;           
    uint segment_count;             
    uint tessellation;              
    uint index_offset;              
    uint vertex_offset;              
    uint ribbon_count;              
    uint ribbon_offset;
    uint segment_offset;
	uint uniform_index;
	uint emitters_index;
	uint graphs_index;
	uint ribbons_index;
	uint ribbon_segments_index;
	uint vertexes_index;
	uint indexes_index;
	uint image_data_index;
	uint sampler_index;
	uint particle_texture_index;
	uint color_ramp_texture_index;
    float lerp;
    float time;
} pc;

layout (local_size_x = group_size) in;

layout (std430, binding = 5) readonly buffer InEmitters {
    tfx_emitter data[];
} emitters[];

layout (std430, binding = 5) readonly buffer InLookups {
    tfx_gpu_graph_data data[];
} graphs[];

layout (std430, binding = 5) buffer InRibbonInstances {
    tfx_ribbon data[];
} ribbons[];

layout (std430, binding = 5) buffer InOutRibbonSegments {
    tfx_ribbon_segment data[];
} ribbon_segments[];

layout (std430, binding = 5) buffer OutVertices {
    tfx_vertex data[];
} vertexes[];

layout (std430, binding = 5) buffer OutIndices {  
    uint data[];
} indexes[];

uint pack_segment_data(uint segment_index, uint ribbon_lerped, uint tessellation, uint tessellation_index, uint side) {
    return (tessellation << 29) | (tessellation_index << 26) | (side << 25) | (ribbon_lerped << 12) | segment_index;
}

vec3 rotate_with_quaternion(vec3 point, vec4 quat) {
    return point + 2.0 * cross(cross(point, quat.xyz) + quat.w * point, quat.xyz);
}

uint pack16bit_sscaled(float x, float y) {
    int x_scaled = int(x * packed_scale_max);
    int y_scaled = int(y * packed_scale_max);
    uint x_bits = uint(x_scaled & 0xFFFF);
    uint y_bits = uint(y_scaled & 0xFFFF) << 16u;
    return x_bits | y_bits;
}

vec4 multiply_quaternions(vec4 q1, vec4 q2) {
    return vec4(
        q1.w * q2.x + q1.x * q2.w + q1.y * q2.z - q1.z * q2.y,  // x
        q1.w * q2.y - q1.x * q2.z + q1.y * q2.w + q1.z * q2.x,  // y
        q1.w * q2.z + q1.x * q2.y - q1.y * q2.x + q1.z * q2.w,  // z
        q1.w * q2.w - q1.x * q2.x - q1.y * q2.y - q1.z * q2.z   // w
    );
}

// -- Perlin noise (3D gradient noise) --
// Hard-coded noise parameters for experimentation
const float noise_frequency = 4.0;       // Spatial frequency / resolution of the noise
const float noise_amplitude = 0.05;      // How much the noise displaces positions
const int   noise_octaves   = 3;         // Turbulence: number of FBM octaves
const float noise_lacunarity = 1.0;      // Frequency multiplier per octave
const float noise_persistence = 0.5;     // Amplitude multiplier per octave
const float noise_time_scale = 0.001;    // How fast the noise animates

vec3 noise_mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
vec4 noise_mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
vec4 noise_permute(vec4 x) { return noise_mod289(((x * 34.0) + 10.0) * x); }
vec4 noise_taylor_inv_sqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }

float perlin3d(vec3 v) {
    const vec2 C = vec2(1.0 / 6.0, 1.0 / 3.0);
    const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);

    // First corner
    vec3 i  = floor(v + dot(v, C.yyy));
    vec3 x0 = v - i + dot(i, C.xxx);

    // Other corners
    vec3 g = step(x0.yzx, x0.xyz);
    vec3 l = 1.0 - g;
    vec3 i1 = min(g.xyz, l.zxy);
    vec3 i2 = max(g.xyz, l.zxy);

    vec3 x1 = x0 - i1 + C.xxx;
    vec3 x2 = x0 - i2 + C.yyy;
    vec3 x3 = x0 - D.yyy;

    // Permutations
    i = noise_mod289(i);
    vec4 p = noise_permute(noise_permute(noise_permute(
             i.z + vec4(0.0, i1.z, i2.z, 1.0))
           + i.y + vec4(0.0, i1.y, i2.y, 1.0))
           + i.x + vec4(0.0, i1.x, i2.x, 1.0));

    // Gradients: 7x7 points over a square, mapped onto an octahedron
    float n_ = 0.142857142857;
    vec3 ns = n_ * D.wyz - D.xzx;

    vec4 j = p - 49.0 * floor(p * ns.z * ns.z);

    vec4 x_ = floor(j * ns.z);
    vec4 y_ = floor(j - 7.0 * x_);

    vec4 x = x_ * ns.x + ns.yyyy;
    vec4 y = y_ * ns.x + ns.yyyy;
    vec4 h = 1.0 - abs(x) - abs(y);

    vec4 b0 = vec4(x.xy, y.xy);
    vec4 b1 = vec4(x.zw, y.zw);

    vec4 s0 = floor(b0) * 2.0 + 1.0;
    vec4 s1 = floor(b1) * 2.0 + 1.0;
    vec4 sh = -step(h, vec4(0.0));

    vec4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
    vec4 a1 = b1.xzyw + s1.xzyw * sh.zzww;

    vec3 p0 = vec3(a0.xy, h.x);
    vec3 p1 = vec3(a0.zw, h.y);
    vec3 p2 = vec3(a1.xy, h.z);
    vec3 p3 = vec3(a1.zw, h.w);

    // Normalise gradients
    vec4 norm = noise_taylor_inv_sqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2,p2), dot(p3,p3)));
    p0 *= norm.x;
    p1 *= norm.y;
    p2 *= norm.z;
    p3 *= norm.w;

    // Mix final noise value
    vec4 m = max(0.5 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
    m = m * m;
    return 105.0 * dot(m * m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
}

